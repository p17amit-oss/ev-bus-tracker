---
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  type?: 'website' | 'article';
  image?: string;
}

const { title, description, canonical, type, image } = Astro.props;
const path = Astro.url.pathname;

const NAV = [
  { href: '/', label: 'Home' },
  { href: '/tenders/', label: 'Tenders' },
  { href: '/oem/', label: 'OEMs' },
  { href: '/registrations/', label: 'Registrations' },
  { href: '/charging/', label: 'Charging Infra' },
  { href: '/states/', label: 'States' },
  { href: '/methodology/', label: 'Methodology' },
];

function active(href: string) {
  if (href === '/') return path === '/' || path === '';
  return path.startsWith(href);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO {title} {description} {canonical} {type} {image} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <slot name="head" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --green: #16a34a; --green-light: #dcfce7; --green-dark: #14532d;
        --blue: #2563eb; --blue-light: #dbeafe; --blue-dark: #1e3a8a;
        --amber: #d97706; --amber-light: #fef3c7;
        --red: #dc2626; --red-light: #fee2e2;
        --purple: #7c3aed; --purple-light: #ede9fe;
        --gray-50: #f9fafb; --gray-100: #f3f4f6; --gray-200: #e5e7eb;
        --gray-300: #d1d5db; --gray-400: #9ca3af; --gray-500: #6b7280;
        --gray-700: #374151; --gray-900: #111827;
        --radius: 8px; --radius-lg: 12px;
        --shadow: 0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.06);
        --shadow-md: 0 4px 6px rgba(0,0,0,.07), 0 2px 4px rgba(0,0,0,.06);
        --font: 'Inter', system-ui, -apple-system, sans-serif;
      }

      body {
        font-family: var(--font);
        background: var(--gray-50);
        color: var(--gray-900);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main { flex: 1; }

      /* ── Nav ── */
      .site-nav {
        background: white;
        border-bottom: 1px solid var(--gray-200);
        position: sticky; top: 0; z-index: 100;
      }
      .nav-inner {
        max-width: 1200px; margin: 0 auto; padding: 0 20px;
        display: flex; align-items: center; height: 52px; gap: 0;
      }
      .nav-brand {
        font-weight: 700; font-size: 14px; color: var(--green-dark);
        text-decoration: none; display: flex; align-items: center; gap: 6px;
        white-space: nowrap; margin-right: 16px; flex-shrink: 0;
      }
      .nav-links {
        display: flex; align-items: center; gap: 2px;
        flex: 1; overflow-x: auto; scrollbar-width: none;
      }
      .nav-links::-webkit-scrollbar { display: none; }
      .nav-links a {
        font-size: 13px; font-weight: 500; color: var(--gray-500);
        text-decoration: none; padding: 5px 9px; border-radius: 6px;
        white-space: nowrap; transition: background .1s, color .1s;
      }
      .nav-links a:hover { color: var(--gray-900); background: var(--gray-100); }
      .nav-links a.active { color: var(--green-dark); background: var(--green-light); font-weight: 600; }
      .nav-subscribe {
        flex-shrink: 0; margin-left: 10px;
        font-size: 12px; font-weight: 600;
        color: white; background: var(--green);
        padding: 5px 12px; border-radius: 6px;
        text-decoration: none; transition: background .15s;
      }
      .nav-subscribe:hover { background: var(--green-dark); }

      /* ── Shared page elements ── */
      .container { max-width: 1100px; margin: 0 auto; padding: 40px 24px; }
      .container-sm { max-width: 820px; margin: 0 auto; padding: 40px 24px; }

      .card {
        background: white; border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg); overflow: hidden;
      }
      .card-header {
        padding: 14px 20px; border-bottom: 1px solid var(--gray-100);
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
      }
      .card-header h2 { font-size: 14px; font-weight: 600; }

      /* ── Tags ── */
      .tag {
        display: inline-flex; align-items: center; gap: 3px;
        font-size: 11px; font-weight: 600; padding: 2px 9px;
        border-radius: 99px; white-space: nowrap;
      }
      .tag-green  { background: var(--green-light);  color: var(--green-dark); }
      .tag-blue   { background: var(--blue-light);   color: var(--blue-dark); }
      .tag-amber  { background: var(--amber-light);  color: var(--amber); }
      .tag-red    { background: var(--red-light);    color: var(--red); }
      .tag-gray   { background: var(--gray-100);     color: var(--gray-700); }
      .tag-purple { background: var(--purple-light); color: var(--purple); }

      .pill { font-size: 12px; color: var(--gray-500); background: var(--gray-100); padding: 2px 10px; border-radius: 99px; }

      /* ── Buttons ── */
      .btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 18px; border-radius: var(--radius);
        font-size: 14px; font-weight: 600; cursor: pointer;
        text-decoration: none; border: none; font-family: var(--font);
        transition: background .15s, opacity .15s;
      }
      .btn-primary { background: var(--green); color: white; }
      .btn-primary:hover { background: var(--green-dark); }
      .btn-outline {
        background: white; color: var(--gray-700);
        border: 1.5px solid var(--gray-300);
      }
      .btn-outline:hover { border-color: var(--gray-500); }
      .btn-sm { padding: 6px 12px; font-size: 13px; }

      /* ── Empty state ── */
      .empty-state { padding: 48px 24px; text-align: center; color: var(--gray-500); }
      .empty-state .es-icon { font-size: 36px; margin-bottom: 12px; }
      .empty-state h3 { font-size: 15px; font-weight: 600; color: var(--gray-700); margin-bottom: 6px; }
      .empty-state p { font-size: 13px; max-width: 320px; margin: 0 auto; }

      /* ── Coming soon lock ── */
      .coming-soon {
        padding: 16px 20px;
        background: repeating-linear-gradient(
          45deg, var(--gray-50), var(--gray-50) 8px, var(--gray-100) 8px, var(--gray-100) 16px
        );
        border: 1px dashed var(--gray-300); border-radius: var(--radius);
        text-align: center; color: var(--gray-500); font-size: 13px;
      }
      .coming-soon strong { color: var(--gray-700); }

      /* ── Source chip ── */
      .source-chip {
        display: inline-flex; align-items: center; gap: 3px;
        font-size: 11px; font-weight: 500; padding: 2px 8px;
        border-radius: 4px; background: var(--gray-100); color: var(--gray-500);
        text-decoration: none; border: 1px solid var(--gray-200);
      }
      .source-chip:hover { color: var(--blue); background: var(--blue-light); border-color: #bfdbfe; }

      /* ── Data table ── */
      .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
      .data-table th {
        font-size: 11px; font-weight: 600; color: var(--gray-500);
        text-transform: uppercase; letter-spacing: .5px;
        padding: 10px 16px; text-align: left;
        background: var(--gray-50); border-bottom: 1px solid var(--gray-200);
        white-space: nowrap;
      }
      .data-table td {
        padding: 12px 16px; border-bottom: 1px solid var(--gray-100);
        vertical-align: top;
      }
      .data-table tr:last-child td { border-bottom: none; }
      .data-table tr:hover td { background: var(--gray-50); }
      .data-table .num { text-align: right; font-weight: 600; color: var(--green); }
      .data-table .muted { color: var(--gray-500); font-size: 12px; }
      .data-table tfoot td {
        background: var(--gray-50); border-top: 2px solid var(--gray-200);
        font-weight: 600;
      }

      /* ── Footer ── */
      .site-footer {
        background: white; border-top: 1px solid var(--gray-200);
        padding: 28px 20px; font-size: 13px; color: var(--gray-500);
      }
      .footer-inner { max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px; }
      .footer-disclaimer {
        background: var(--gray-50); border: 1px solid var(--gray-200);
        border-radius: var(--radius); padding: 10px 14px;
        font-size: 12px; line-height: 1.6; color: var(--gray-500);
      }
      .footer-links { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
      .footer-links a { color: var(--gray-500); text-decoration: none; }
      .footer-links a:hover { color: var(--gray-900); }
      .footer-sep { color: var(--gray-300); }
      .footer-copy { font-size: 12px; color: var(--gray-400); }

      @media (max-width: 640px) {
        .container, .container-sm { padding: 24px 14px; }
        .nav-inner { padding: 0 14px; }
      }
    </style>
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a class="nav-brand" href="/">🚌 EV Bus Tracker</a>
        <div class="nav-links">
          {NAV.map(({ href, label }) => (
            <a href={href} class={active(href) ? 'active' : ''}>{label}</a>
          ))}
        </div>
        <a class="nav-subscribe" href="/subscribe/">Subscribe</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-disclaimer">
          <strong>Disclaimer:</strong> This tracker uses public sources only. Data may contain delays or errors.
          Always verify against original source documents before commercial decisions.
          Not affiliated with any government agency, OEM, STU, operator, or employer.
        </p>
        <div class="footer-links">
          <a href="/">Home</a>
          <span class="footer-sep">·</span>
          <a href="/methodology/">Methodology</a>
          <span class="footer-sep">·</span>
          <a href="/methodology/#sources">Sources</a>
          <span class="footer-sep">·</span>
          <a href="/methodology/#disclaimer">Disclaimer</a>
          <span class="footer-sep">·</span>
          <a href="/subscribe/">Subscribe</a>
          <span class="footer-sep">·</span>
          <a href="/tenders/">Tenders</a>
          <span class="footer-sep">·</span>
          <a href="/oem/">OEMs</a>
        </div>
        <div class="footer-copy">India EV Bus Tracker · Public-source intelligence · Updated daily</div>
      </div>
    </footer>
  </body>
</html>

---
import Layout from '../layouts/Layout.astro';
import StatusBadge from '../components/StatusBadge.astro';
import ConfidenceBadge from '../components/ConfidenceBadge.astro';
import tenders from '../data/tenders.json';
import organizations from '../data/organizations.json';
import deployments from '../data/deployments.json';
import charging from '../data/charging_infra.json';
import activity from '../data/activity_feed.json';
import states from '../data/states.json';
import registrations from '../data/registrations_monthly.json';

const BUILD_DATE = new Date('2026-06-14');

function effectiveStatus(t: any): string {
  const declared = (t.status as string) ?? 'unknown';
  if (declared === 'awarded' || declared === 'cancelled') return declared;
  const dl: string | null = t.bid_due_date ?? null;
  if (!dl) return declared || 'unknown';
  const deadline = new Date(dl);
  const diffDays = Math.ceil((deadline.getTime() - BUILD_DATE.getTime()) / 864e5);
  if (diffDays < 0) return declared === 'extended' ? 'extended' : 'needs_review';
  if (diffDays <= 7) return 'closing_soon';
  return 'open';
}

const oems = organizations.filter(o => o.org_type === 'oem');
const enriched = tenders.map(t => ({ ...t, effStatus: effectiveStatus(t) }));
const openTenders = enriched.filter(t => ['open','closing_soon'].includes(t.effStatus));
const needsReview = enriched.filter(t => t.effStatus === 'needs_review');
const totalBusesInPlay = openTenders.reduce((s, t) => s + (t.bus_count ?? 0), 0);
const hasRegistrations = registrations.length > 0;

const oemStats = oems.map(o => {
  const deps = deployments.filter(d => d.oem_name === o.name);
  const total = deps.reduce((s, d) => s + (d.bus_count ?? 0), 0);
  const cities = [...new Set(deps.map(d => d.city).filter(Boolean))] as string[];
  return { ...o, totalDeployed: total, cities };
}).sort((a, b) => b.totalDeployed - a.totalDeployed);

const EVENT_LABELS: Record<string, { label: string; cls: string }> = {
  tender_added:   { label: 'New Tender',    cls: 'tag-green' },
  status_change:  { label: 'Status Update', cls: 'tag-amber' },
  data_update:    { label: 'Data Update',   cls: 'tag-blue'  },
  monitor_update: { label: 'Monitor',       cls: 'tag-gray'  },
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "India Electric Bus Intelligence Tracker",
  "url": "https://ev-bus-tracker.pages.dev",
  "description": "Public-source tracker for e-bus tenders, OEM activity, registrations, deployments, and charging infra across India.",
  "inLanguage": "en-IN",
};
---
<Layout
  title="India Electric Bus Intelligence Tracker — Tenders, OEM Orders & Registrations"
  description={`Public-source tracker for India's electric bus market: ${openTenders.length} live tenders (${totalBusesInPlay.toLocaleString('en-IN')} buses), OEM order disclosures from BSE, and monthly Vahan registration data. Updated daily.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <style>
    .hero {
      background: #0f2922; color: white;
      padding: 56px 24px 48px; text-align: center;
    }
    .hero-eyebrow {
      font-size: 12px; font-weight: 600; letter-spacing: 1px;
      text-transform: uppercase; color: rgba(255,255,255,.5); margin-bottom: 16px;
    }
    .hero h1 {
      font-size: clamp(26px, 5vw, 44px); font-weight: 700; line-height: 1.15;
      margin-bottom: 16px; max-width: 680px; margin-left: auto; margin-right: auto;
    }
    .hero p {
      font-size: 16px; color: rgba(255,255,255,.72);
      max-width: 540px; margin: 0 auto 32px; line-height: 1.6;
    }
    .hero-ctas { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
    .cta-primary {
      font-size: 14px; font-weight: 600; padding: 11px 22px;
      background: var(--green); color: white; border-radius: var(--radius);
      text-decoration: none; transition: background .15s;
    }
    .cta-primary:hover { background: #15803d; }
    .cta-ghost {
      font-size: 14px; font-weight: 500; padding: 11px 22px;
      background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
      color: white; border-radius: var(--radius); text-decoration: none;
      transition: background .15s;
    }
    .cta-ghost:hover { background: rgba(255,255,255,.18); }

    /* Snapshot bar */
    .snapshot-bar { background: white; border-bottom: 1px solid var(--gray-200); }
    .snapshot-inner {
      max-width: 1100px; margin: 0 auto; padding: 0 24px;
      display: flex; overflow-x: auto; scrollbar-width: none;
    }
    .snapshot-inner::-webkit-scrollbar { display: none; }
    .snap-card {
      flex: 1; min-width: 130px; padding: 16px 18px;
      border-right: 1px solid var(--gray-100); text-align: center;
    }
    .snap-card:last-child { border-right: none; }
    .snap-num { font-size: 22px; font-weight: 700; color: var(--gray-900); line-height: 1; }
    .snap-lbl { font-size: 11px; color: var(--gray-500); margin-top: 3px; }
    .snap-note { font-size: 10px; color: var(--gray-300); margin-top: 1px; }

    /* Sections */
    .section { padding: 40px 24px; }
    .section-alt { background: var(--gray-50); }
    .section-white { background: white; border-top: 1px solid var(--gray-200); }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .sec-title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
    .sec-sub { font-size: 13px; color: var(--gray-500); margin-bottom: 20px; }

    /* Activity feed */
    .activity-list { display: flex; flex-direction: column; gap: 10px; }
    .activity-item {
      background: white; border: 1px solid var(--gray-200); border-radius: var(--radius-lg);
      padding: 13px 16px; display: flex; gap: 12px; align-items: flex-start;
    }
    .act-left { flex-shrink: 0; min-width: 100px; }
    .act-date { font-size: 11px; color: var(--gray-400); font-weight: 500; margin-bottom: 4px; }
    .act-right { flex: 1; }
    .act-title { font-size: 13px; font-weight: 600; color: var(--gray-900); margin-bottom: 3px; line-height: 1.3; }
    .act-title a { color: inherit; text-decoration: none; }
    .act-title a:hover { color: var(--blue); }
    .act-summary { font-size: 12px; color: var(--gray-600); line-height: 1.5; }
    .act-footer { margin-top: 5px; display: flex; gap: 6px; align-items: center; }

    /* Tender pipeline */
    .tender-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 680px) { .tender-cols { grid-template-columns: 1fr; } }
    .t-item { padding: 13px 18px; border-bottom: 1px solid var(--gray-100); }
    .t-item:last-child { border-bottom: none; }
    .t-link {
      font-size: 13px; font-weight: 500; color: var(--gray-900);
      text-decoration: none; line-height: 1.4; display: block; margin-bottom: 7px;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .t-link:hover { color: var(--blue); }
    .t-meta { display: flex; gap: 6px; flex-wrap: wrap; }

    /* OEM grid */
    .oem-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); gap: 12px; }
    .oem-chip {
      background: white; border: 1px solid var(--gray-200); border-radius: var(--radius-lg);
      padding: 16px 18px; text-decoration: none; color: inherit;
      display: flex; flex-direction: column; gap: 8px;
      transition: border-color .15s, box-shadow .15s;
    }
    .oem-chip:hover { border-color: var(--green); box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .oem-chip-name { font-size: 13px; font-weight: 600; }
    .oem-chip-buses { font-size: 20px; font-weight: 700; color: var(--green); line-height: 1; }
    .oem-chip-lbl { font-size: 10px; color: var(--gray-400); }
    .oem-chip-cities { display: flex; gap: 3px; flex-wrap: wrap; }
    .city-chip-sm { font-size: 10px; background: var(--gray-100); color: var(--gray-600); padding: 1px 6px; border-radius: 99px; }
    .oem-chip-arrow { font-size: 12px; color: var(--gray-400); margin-top: auto; }

    /* Charging */
    .charging-list { display: flex; flex-direction: column; gap: 10px; }
    .charging-item {
      background: white; border: 1px solid var(--gray-200); border-radius: var(--radius-lg);
      padding: 13px 18px; display: flex; justify-content: space-between; align-items: center; gap: 12px;
    }
    .charging-name { font-size: 13px; font-weight: 600; margin-bottom: 3px; }
    .charging-detail { font-size: 12px; color: var(--gray-500); }
    .charging-badges { display: flex; gap: 6px; flex-shrink: 0; }

    /* Reg placeholder */
    .reg-ph {
      background: white; border: 1px solid var(--gray-200); border-radius: var(--radius-lg);
      padding: 32px 24px; text-align: center;
    }
    .reg-ph h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
    .reg-ph p { font-size: 13px; color: var(--gray-500); max-width: 380px; margin: 0 auto 16px; line-height: 1.6; }

    /* Newsletter */
    .nl-section { background: #0f2922; color: white; padding: 56px 24px; text-align: center; }
    .nl-section h2 { font-size: clamp(18px,3vw,26px); font-weight: 700; margin-bottom: 10px; }
    .nl-section p { font-size: 14px; color: rgba(255,255,255,.7); max-width: 500px; margin: 0 auto 24px; line-height: 1.6; }
    .nl-perks { display: flex; justify-content: center; gap: 18px; flex-wrap: wrap; margin-bottom: 24px; }
    .nl-perk { font-size: 12px; color: rgba(255,255,255,.6); display: flex; gap: 5px; align-items: center; }

    /* Method banner */
    .method-banner {
      background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: var(--radius-lg);
      padding: 18px 22px; display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap;
    }
    .method-banner p { font-size: 13px; color: var(--gray-600); flex: 1; max-width: 580px; line-height: 1.6; }
  </style>

  <!-- Hero -->
  <div class="hero">
    <div class="hero-eyebrow">Public-source intelligence</div>
    <h1>India Electric Bus<br/>Intelligence Tracker</h1>
    <p>Source-backed data on e-bus tenders, OEM activity, registrations, deployments, and charging infra — updated daily from public sources.</p>
    <div class="hero-ctas">
      <a class="cta-primary" href="/tenders/">Explore Tenders</a>
      <a class="cta-ghost" href="/subscribe/">Subscribe to Digest</a>
      <a class="cta-ghost" href="/methodology/">View Methodology</a>
    </div>
  </div>

  <!-- Market snapshot -->
  <div class="snapshot-bar">
    <div class="snapshot-inner">
      <div class="snap-card">
        <div class="snap-num">{openTenders.length}</div>
        <div class="snap-lbl">Open Tenders</div>
        <div class="snap-note">PM e-Bus Sewa, CESL</div>
      </div>
      <div class="snap-card">
        <div class="snap-num">{totalBusesInPlay.toLocaleString('en-IN')}</div>
        <div class="snap-lbl">Buses in Play</div>
        <div class="snap-note">Active tenders</div>
      </div>
      <div class="snap-card">
        <div class="snap-num">{oems.length}</div>
        <div class="snap-lbl">OEMs Tracked</div>
        <div class="snap-note">BSE monitored</div>
      </div>
      <div class="snap-card">
        <div class="snap-num">{states.length}</div>
        <div class="snap-lbl">States Tracked</div>
        <div class="snap-note">With known activity</div>
      </div>
      <div class="snap-card">
        <div class="snap-num">{charging.length}</div>
        <div class="snap-lbl">Charging Projects</div>
        <div class="snap-note">Infra scope tracked</div>
      </div>
      <div class="snap-card">
        <div class="snap-num">{BUILD_DATE.toISOString().slice(0,10)}</div>
        <div class="snap-lbl">Last Updated</div>
        <div class="snap-note">Daily scrape</div>
      </div>
    </div>
  </div>

  <!-- Activity feed -->
  <div class="section section-alt">
    <div class="section-inner">
      <div class="sec-title">What Changed Recently</div>
      <div class="sec-sub">Latest updates from automated scrapers and manual review — tender status changes, new disclosures, data updates.</div>
      <div class="activity-list">
        {(activity as any[]).slice(0, 5).map(ev => {
          const cfg = EVENT_LABELS[ev.event_type] ?? { label: ev.event_type, cls: 'tag-gray' };
          return (
            <div class="activity-item">
              <div class="act-left">
                <div class="act-date">{ev.event_date}</div>
                <span class={`tag ${cfg.cls}`}>{cfg.label}</span>
              </div>
              <div class="act-right">
                <div class="act-title">
                  {ev.entity_slug
                    ? <a href={`/tenders/${ev.entity_slug}/`}>{ev.title}</a>
                    : ev.title
                  }
                </div>
                <div class="act-summary">{ev.summary}</div>
                {ev.source_label && (
                  <div class="act-footer">
                    {ev.source_url
                      ? <a href={ev.source_url} target="_blank" rel="noopener" class="source-chip">🔗 {ev.source_label}</a>
                      : <span class="source-chip">{ev.source_label}</span>
                    }
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Tender pipeline -->
  <div class="section section-white">
    <div class="section-inner">
      <div class="sec-title">Tender Pipeline</div>
      <div class="sec-sub">Live and recently changed tenders. Statuses computed from bid deadlines — expired tenders are never shown as Open.</div>
      <div class="tender-cols">
        <div class="card">
          <div class="card-header">
            <h2>Open Tenders</h2>
            <span class="pill">{openTenders.length}</span>
          </div>
          {openTenders.length === 0 ? (
            <div class="empty-state">
              <div class="es-icon">📋</div>
              <h3>No open tenders right now</h3>
              <p>CESL tenders update frequently. Check back soon.</p>
            </div>
          ) : openTenders.map(t => (
            <div class="t-item">
              <a class="t-link" href={`/tenders/${t.slug}/`}>
                {(t.display_title ?? t.title)?.slice(0, 100)}
              </a>
              <div class="t-meta">
                <StatusBadge status={t.effStatus} />
                {t.bus_count && <span class="tag tag-green">{t.bus_count.toLocaleString('en-IN')} buses</span>}
                {t.procurement_model && (
                  <span class="tag tag-gray">{t.procurement_model?.toUpperCase()}</span>
                )}
                {t.bid_due_date && (
                  <span class="tag tag-amber">Due {t.bid_due_date}</span>
                )}
              </div>
            </div>
          ))}
        </div>

        <div class="card">
          <div class="card-header">
            <h2>Needs Review</h2>
            <span class="pill">{needsReview.length}</span>
          </div>
          {needsReview.length === 0 ? (
            <div class="empty-state">
              <div class="es-icon">✓</div>
              <h3>All tenders current</h3>
              <p>No expired deadlines pending review.</p>
            </div>
          ) : needsReview.map(t => (
            <div class="t-item">
              <a class="t-link" href={`/tenders/${t.slug}/`}>
                {(t.display_title ?? t.title)?.slice(0, 100)}
              </a>
              <div class="t-meta">
                <StatusBadge status={t.effStatus} />
                {t.bus_count && <span class="tag tag-gray">{t.bus_count.toLocaleString('en-IN')} buses</span>}
                {t.bid_due_date && (
                  <span class="tag tag-amber">Deadline: {t.bid_due_date}</span>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
      <div style="margin-top:12px;text-align:right">
        <a href="/tenders/" class="btn btn-outline btn-sm">All tenders →</a>
      </div>
    </div>
  </div>

  <!-- OEM activity -->
  <div class="section section-alt">
    <div class="section-inner">
      <div class="sec-title">OEM Activity</div>
      <div class="sec-sub">Known operational buses per OEM from public annual reports and press releases. Confidence: medium.</div>
      <div class="oem-grid">
        {oemStats.map(o => (
          <a class="oem-chip" href={`/oem/${o.slug}/`}>
            <div class="oem-chip-name">{o.name}</div>
            {o.totalDeployed > 0 ? (
              <>
                <div>
                  <div class="oem-chip-buses">{o.totalDeployed.toLocaleString('en-IN')}</div>
                  <div class="oem-chip-lbl">buses known operational</div>
                </div>
                <div class="oem-chip-cities">
                  {o.cities.slice(0, 3).map(c => <span class="city-chip-sm">{c}</span>)}
                  {o.cities.length > 3 && <span class="city-chip-sm">+{o.cities.length - 3}</span>}
                </div>
              </>
            ) : (
              <div style="font-size:11px;color:var(--gray-400)">No deployment data yet</div>
            )}
            {o.bse_scrip_code && <span class="source-chip">BSE {o.bse_scrip_code}</span>}
            <div class="oem-chip-arrow">View profile →</div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Charging preview -->
  <div class="section section-white">
    <div class="section-inner">
      <div class="sec-title">Charging Infra Pipeline</div>
      <div class="sec-sub">Charging and depot infra scope extracted from bus tender documents. GCC tenders include civil and electrical infra as bundled scope.</div>
      <div class="charging-list">
        {(charging as any[]).map(p => (
          <div class="charging-item">
            <div>
              <div class="charging-name">{p.project_name}</div>
              <div class="charging-detail">
                {p.bus_count_linked ? `${p.bus_count_linked.toLocaleString('en-IN')} buses ·` : ''} {p.state}
                {p.bundled_with_bus_tender ? ' · Bundled (GCC)' : ''}
              </div>
            </div>
            <div class="charging-badges">
              <StatusBadge status={p.status} />
              <ConfidenceBadge label={p.confidence_label} />
            </div>
          </div>
        ))}
      </div>
      <div style="margin-top:12px;text-align:right">
        <a href="/charging/" class="btn btn-outline btn-sm">View charging infra →</a>
      </div>
    </div>
  </div>

  <!-- Registration placeholder -->
  <div class="section section-alt">
    <div class="section-inner">
      <div class="sec-title">Registration Data</div>
      <div class="sec-sub">Monthly Vahan analytics — maker-wise and state-wise e-bus registrations.</div>
      {hasRegistrations ? (
        <div><!-- registration table --></div>
      ) : (
        <div class="reg-ph">
          <h3>Vahan registration module coming soon</h3>
          <p>Monthly e-bus registration data from Vahan Analytics is being set up. Data will show maker-wise and state-wise counts once the local scraper runs.</p>
          <a href="/registrations/" class="btn btn-outline btn-sm">Learn about the module →</a>
        </div>
      )}
    </div>
  </div>

  <!-- Newsletter CTA -->
  <div class="nl-section">
    <h2>Weekly E-Bus Market Digest</h2>
    <p>Tenders, OEM disclosures, Vahan registration snapshots, and policy updates — every Monday. Free.</p>
    <div class="nl-perks">
      <span class="nl-perk">📋 Live tenders with deadlines</span>
      <span class="nl-perk">📢 BSE order signals filtered</span>
      <span class="nl-perk">📊 Monthly registration snapshot</span>
    </div>
    <a class="cta-primary" href="/subscribe/">Subscribe — it's free</a>
  </div>

  <!-- Methodology CTA -->
  <div class="section" style="padding:20px 24px;background:white;border-top:1px solid var(--gray-200)">
    <div style="max-width:1100px;margin:0 auto">
      <div class="method-banner">
        <p>
          <strong>How is this data collected?</strong> Every record comes from a public source —
          government portals, stock exchange filings, or official tender documents. Confidence
          scores indicate source reliability. Expired tender deadlines are never shown as Open.
        </p>
        <a href="/methodology/" class="btn btn-outline btn-sm">Read methodology →</a>
      </div>
    </div>
  </div>
</Layout>
